# ═══════════════════════════════════════════
# NexusClaw — Environment Configuration
# ═══════════════════════════════════════════

# LLM Provider: openai | anthropic | openrouter
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=gpt-4o

# Server
PORT=3100
HOST=0.0.0.0

# Encryption (64 hex chars = 256-bit key)
ENCRYPTION_KEY=

# OAuth Providers (for Antigravity - Google OAuth)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# Discord
DISCORD_BOT_TOKEN=

# Redis (optional)
REDIS_URL=redis://localhost:6379

# GitHub Integration (for github tool — create PRs, issues, branches)
# Get token: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Brave Search (for web_search tool)
BRAVE_API_KEY=

# Security
RESTRICT_TO_WORKSPACE=false
