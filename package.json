{
    "name": "nexusclaw",
    "version": "0.1.0",
    "description": "🐾 NexusClaw: Ultra-Lightweight Secure AI Agent Platform with Browser Control and Zero-Trust Security",
    "type": "module",
    "main": "dist/index.js",
    "bin": {
        "nexusclaw": "./dist/cli/index.js"
    },
    "scripts": {
        "dev": "npx cross-env NODE_OPTIONS=--max-old-space-size=2048 tsx watch --no-warnings src/cli/index.ts",
        "build": "tsc",
        "start": "npx cross-env NODE_OPTIONS=--max-old-space-size=2048 node --no-warnings dist/cli/index.js",
        "typecheck": "tsc --noEmit",
        "agent": "npx cross-env NODE_OPTIONS=--max-old-space-size=2048 tsx --no-warnings src/cli/index.ts agent",
        "gateway": "npx cross-env NODE_OPTIONS=--max-old-space-size=2048 tsx --no-warnings src/cli/index.ts gateway",
        "status": "tsx --no-warnings src/cli/index.ts status",
        "onboard": "tsx --no-warnings src/cli/index.ts onboard",
        "cli": "node --no-warnings dist/cli/index.js"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.30.0",
        "@fastify/cors": "^11.2.0",
        "@fastify/static": "^9.0.0",
        "@fastify/websocket": "^11.2.0",
        "@langchain/core": "^1.1.27",
        "@langchain/langgraph": "^1.1.5",
        "@langchain/openai": "^1.2.9",
        "@whiskeysockets/baileys": "^6.7.0",
        "chalk": "^5.3.0",
        "cheerio": "^1.0.0",
        "commander": "^12.0.0",
        "cron": "^3.5.0",
        "discord.js": "^14.25.1",
        "express": "^5.2.1",
        "fastify": "^5.7.4",
        "gradient-string": "^3.0.0",
        "inquirer": "^13.2.5",
        "ioredis": "^5.4.0",
        "nanoid": "^5.0.0",
        "openai": "^4.60.0",
        "ora": "^8.0.0",
        "pino": "^9.0.0",
        "pino-pretty": "^11.0.0",
        "playwright": "^1.45.0",
        "qrcode-terminal": "^0.12.0",
        "readline": "^1.3.0",
        "telegraf": "^4.16.0",
        "whatsapp-web.js": "^1.34.6",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@fastify/compress": "^8.3.1",
        "@types/node": "^25.3.0",
        "@types/qrcode-terminal": "^0.12.2",
        "tsx": "^4.16.0",
        "typescript": "^5.5.0",
        "vite-plugin-compression2": "^2.4.0"
    }
}